{
  "name": "@lumen/server",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm --prefix ../packages/protocol run build && tsx watch src/index.ts",
    "build": "npm --prefix ../packages/protocol run build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "npm --prefix ../packages/protocol run build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "@lumen/protocol": "file:../packages/protocol",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
